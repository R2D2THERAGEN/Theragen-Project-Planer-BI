/// Person directory (DM D02). Owners, requesters and assignees on facts.
table Person
	lineageTag: b4c6cdec-1a41-5001-b43e-dd06efbc25e0

	/// (hidden) Surrogate key uniquely identifying the person; the relationship anchor for owner/requester/assignee joins on facts.
	column 'Person ID'
		dataType: string
		isHidden
		lineageTag: 8a36c70d-b5a1-58fb-9953-3148e215b563
		summarizeBy: none
		sourceColumn: Person ID

		annotation SummarizationSetBy = User

	/// Display name of the person; the label shown for owners, requesters and assignees across facts.
	column Person
		dataType: string
		lineageTag: 34350de5-beb8-5edf-86a3-673e1258680c
		summarizeBy: none
		sourceColumn: Person

		annotation SummarizationSetBy = User

	/// Person's email address (work UPN); the identity used to match RLS report-access grants.
	column Email
		dataType: string
		lineageTag: 26ed695f-8b9e-5b1a-ab10-22c8c36c8128
		summarizeBy: none
		sourceColumn: Email

		annotation SummarizationSetBy = User

	/// The Theragen department the person belongs to (one of the 8 departments).
	column 'Person Department'
		dataType: string
		lineageTag: 58bb88a2-1793-516b-b410-823c9ef29b76
		summarizeBy: none
		sourceColumn: Person Department

		annotation SummarizationSetBy = User

	/// The person's job title or role within the organization.
	column 'Role Title'
		dataType: string
		lineageTag: 11796fc0-b073-5de3-a0f8-dda5fee14e7e
		summarizeBy: none
		sourceColumn: Role Title

		annotation SummarizationSetBy = User

	/// HR employee identifier for the person; the directory's stable payroll key.
	column 'Employee Number'
		dataType: string
		lineageTag: 62ecdf90-9dcd-5d73-a8a2-1bfcac8cd2c0
		summarizeBy: none
		sourceColumn: Employee Number

		annotation SummarizationSetBy = User

	partition Person = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database(PgServer, PgDatabase),
				    Data = Source{[Schema = "bi", Item = "person"]}[Data],
				    Selected = Table.SelectColumns(Data, {"person_id", "display_name", "email", "department_name", "role_title", "employee_number"}),
				    Renamed = Table.RenameColumns(Selected, {{"person_id", "Person ID"}, {"display_name", "Person"}, {"email", "Email"}, {"department_name", "Person Department"}, {"role_title", "Role Title"}, {"employee_number", "Employee Number"}})
				in
				    Renamed

	annotation PBI_ResultType = Table

