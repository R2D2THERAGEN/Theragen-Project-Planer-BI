/// Fact - project closure checklist items (PMBOK P26).
table 'Closure Item'
	lineageTag: 0baea3eb-cf6e-5574-9898-aebde8eeb1aa

	column 'Closure Item ID'
		dataType: string
		isHidden
		lineageTag: f8bb778e-8e48-5a8c-a69e-9f4c78831889
		summarizeBy: none
		sourceColumn: Closure Item ID

		annotation SummarizationSetBy = User

	column 'Project ID'
		dataType: string
		isHidden
		lineageTag: 4131030c-31fb-58d5-be12-2ee6f7071374
		summarizeBy: none
		sourceColumn: Project ID

		annotation SummarizationSetBy = User

	column 'Project Code'
		dataType: string
		lineageTag: 820d0ace-16b7-5c32-8bc8-a01831f13971
		summarizeBy: none
		sourceColumn: Project Code

		annotation SummarizationSetBy = User

	column 'Closure Item'
		dataType: string
		lineageTag: 9f47aa21-cea2-5ede-b630-ee20e837a39c
		summarizeBy: none
		sourceColumn: Closure Item

		annotation SummarizationSetBy = User

	column 'Owner Role'
		dataType: string
		lineageTag: 96d29f93-c478-5202-a5a3-10fafafe62b7
		summarizeBy: none
		sourceColumn: Owner Role

