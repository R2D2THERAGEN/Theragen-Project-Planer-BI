/// Fact - project closure checklist items (PMBOK P26).
table 'Closure Item'
	lineageTag: 0baea3eb-cf6e-5574-9898-aebde8eeb1aa

	/// (hidden) Surrogate key of the closure-checklist row; joins to the closure source.
	column 'Closure Item ID'
		dataType: string
		isHidden
		lineageTag: f8bb778e-8e48-5a8c-a69e-9f4c78831889
		summarizeBy: none
		sourceColumn: Closure Item ID

		annotation SummarizationSetBy = User

	/// (hidden) Surrogate key of the owning project; joins to the Project dimension.
	column 'Project ID'
		dataType: string
		isHidden
		lineageTag: 4131030c-31fb-58d5-be12-2ee6f7071374
		summarizeBy: none
		sourceColumn: Project ID

		annotation SummarizationSetBy = User

	/// Human-readable project code the closure item belongs to.
	column 'Project Code'
		dataType: string
		lineageTag: 820d0ace-16b7-5c32-8bc8-a01831f13971
		summarizeBy: none
		sourceColumn: Project Code

		annotation SummarizationSetBy = User

	/// Text of the project-closeout checklist entry to be completed.
	column 'Closure Item'
		dataType: string
		lineageTag: 9f47aa21-cea2-5ede-b630-ee20e837a39c
		summarizeBy: none
		sourceColumn: Closure Item

