		annotation SummarizationSetBy = User

	partition 'Closure Item' = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(DataFolder & "\closure_checklist_item.csv"), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				    Selected = Table.SelectColumns(Promoted, {"closure_item_id", "project_id", "project_code", "item", "owner_role", "done", "evidence"}),
				    Nulled = Table.ReplaceValue(Selected, "", null, Replacer.ReplaceValue, Table.ColumnNames(Selected)),
				    Typed = Table.TransformColumnTypes(Nulled, {{"closure_item_id", type text}, {"project_id", type text}, {"project_code", type text}, {"item", type text}, {"owner_role", type text}, {"done", type logical}, {"evidence", type text}}),
				    Renamed = Table.RenameColumns(Typed, {{"closure_item_id", "Closure Item ID"}, {"project_id", "Project ID"}, {"project_code", "Project Code"}, {"item", "Closure Item"}, {"owner_role", "Owner Role"}, {"done", "Done"}, {"evidence", "Evidence"}})
				in
				    Renamed

	annotation PBI_ResultType = Table

