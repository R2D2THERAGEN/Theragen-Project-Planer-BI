/// Data-driven RLS: a member sees only the projects granted to their UPN in the Report Access table (Project / Department / All), via the union of their active grants. Default-deny - no grant = no rows.
role 'Scoped Viewer'
	modelPermission: read
	lineageTag: 6f82a8e8-dc47-5e99-82a5-b531d63d7d90

	tablePermission Project = COUNTROWS(FILTER('Report Access', 'Report Access'[Active] = TRUE() && LOWER('Report Access'[User Email]) = LOWER(USERPRINCIPALNAME()) && ('Report Access'[Scope Type] = "All" || ('Report Access'[Scope Type] = "Project" && 'Report Access'[Scope Value] = 'Project'[Project Code]) || ('Report Access'[Scope Type] = "Department" && 'Report Access'[Scope Value] = 'Project'[Primary Department])))) > 0
