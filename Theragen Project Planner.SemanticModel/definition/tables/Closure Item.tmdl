	/// Reference or note evidencing that the item was completed.
	column Evidence
		dataType: string
		lineageTag: 2bb9342e-582b-5f2a-9301-c1456ca1086c
		summarizeBy: none
		sourceColumn: Evidence

		annotation SummarizationSetBy = User

	partition 'Closure Item' = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database(PgServer, PgDatabase),
				    Data = Source{[Schema = "bi", Item = "closure_checklist_item"]}[Data],
				    Selected = Table.SelectColumns(Data, {"closure_item_id", "project_id", "project_code", "item", "owner_role", "done", "evidence"}),
				    Renamed = Table.RenameColumns(Selected, {{"closure_item_id", "Closure Item ID"}, {"project_id", "Project ID"}, {"project_code", "Project Code"}, {"item", "Closure Item"}, {"owner_role", "Owner Role"}, {"done", "Done"}, {"evidence", "Evidence"}})
				in
				    Renamed

	annotation PBI_ResultType = Table

