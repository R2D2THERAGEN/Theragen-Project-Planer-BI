	/// Role accountable for completing the checklist item.
	column 'Owner Role'
		dataType: string
		lineageTag: 96d29f93-c478-5202-a5a3-10fafafe62b7
		summarizeBy: none
		sourceColumn: Owner Role

		annotation SummarizationSetBy = User

	/// TRUE when the checklist item has been completed.
	column Done
		dataType: boolean
		lineageTag: 3929b9c5-9b6b-55d5-9470-e61770cbf624
		summarizeBy: none
		sourceColumn: Done

