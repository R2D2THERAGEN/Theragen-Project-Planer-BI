/// PMBOK knowledge areas (enum knowledge_area) used by status report health entries.
table 'Knowledge Area'
	lineageTag: 3e1491d6-a5e0-5681-a32b-f292fddfcd72

	/// PMI knowledge area (e.g. Scope, Schedule, Cost, Quality, Risk) used to structure status-report health entries.
	column 'Knowledge Area'
		dataType: string
		lineageTag: f27bd9cd-fc01-5b41-8aa1-adf9c35d9b8f
		summarizeBy: none
		sourceColumn: Knowledge Area
		sortByColumn: 'KA Sort'

		annotation SummarizationSetBy = User

	/// (hidden) Sort order that lays out knowledge areas in canonical PMI sequence rather than alphabetically.
	column 'KA Sort'
		dataType: int64
		isHidden
		lineageTag: 9bb16f73-9f00-57e0-a608-7176c9c24580
		summarizeBy: none
		sourceColumn: KA Sort

		annotation SummarizationSetBy = User

	partition 'Knowledge Area' = m
		mode: import
		source =
				let
				    Source = PostgreSQL.Database(PgServer, PgDatabase),
				    Data = Source{[Schema = "bi", Item = "knowledge_area"]}[Data],
				    Selected = Table.SelectColumns(Data, {"knowledge_area", "sort_order"}),
				    Renamed = Table.RenameColumns(Selected, {{"knowledge_area", "Knowledge Area"}, {"sort_order", "KA Sort"}})
				in
				    Renamed

	annotation PBI_ResultType = Table

